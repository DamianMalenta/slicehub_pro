# 🟢 FIX 1: Wymuś poprawny Content-Type dla manifestu PWA
<Files "manifest_admin.json">
  ForceType application/manifest+json
</Files>

# 🟢 FIX 2: Zabezpiecz Service Workera przed nadpisaniem
<Files "sw.js">
  Header set Service-Worker-Allowed "/"
</Files>

# 🟢 FIX 3: Wymuś brak buforowania dla PWA (żeby zmiany działały)
<FilesMatch "\.(json|js|html)$">
  Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
</FilesMatch>