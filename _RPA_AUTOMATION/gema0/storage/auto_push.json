      "mention_syntax": true,
      "preflight_esc": false,
      "cooldown_ms": 8000,
      "dedupe_by_hash": true
    }
  ],
  "push_after_save_note": {
    "enabled": false,
    "require_main_auto_push_enabled": true,
    "target": "CURSOR_1",
    "extra_instruction": "Zastosuj treść notatki @.",
    "mention_syntax": true,
    "preflight_esc": false
  }
}
