# =============================================================================
# SliceHub Pro — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Legacy / archiwa (trzymane offline na dysku, poza repo)
# -----------------------------------------------------------------------------
_KOPALNIA_WIEDZY_LEGACY/

# -----------------------------------------------------------------------------
# Środowisko / sekrety
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env

# -----------------------------------------------------------------------------
# IDE / edytory
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# PHP / Composer
# -----------------------------------------------------------------------------
vendor/
composer.phar
composer.lock

# -----------------------------------------------------------------------------
# Logi / cache / tmp
# -----------------------------------------------------------------------------
*.log
logs/
cache/
tmp/
temp/
storage/tmp/

# -----------------------------------------------------------------------------
# Uploady / assety runtime (NIE commitujemy treści wrzucanych przez usera)
# -----------------------------------------------------------------------------
uploads/
public/uploads/
storage/uploads/

# -----------------------------------------------------------------------------
# Bazy / dumpy lokalne (nie wrzucamy dumpów do repo)
# -----------------------------------------------------------------------------
*.sql.bak
*_DUMP_*.sql
*.sqlite
*.sqlite3

# -----------------------------------------------------------------------------
# Node (gdybyśmy kiedyś mieli, choć Konstytucja mówi "zakaz")
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*

# -----------------------------------------------------------------------------
# Cursor / AI tooling
# -----------------------------------------------------------------------------
.cursor/plans/
